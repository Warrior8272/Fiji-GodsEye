def rendezvous_status():
    import json
    from pathlib import Path

    now_ts = time.time()
    ais_path = Path(__file__).resolve().parent / "ais_live.json"

    try:
        data = json.loads(ais_path.read_text()) if ais_path.exists() else []
    except Exception as e:
        return jsonify({"status": "error", "message": str(e), "rendezvous": []})

    vessels = list(data.values()) if isinstance(data, dict) else data
    candidates = []

    for i, a in enumerate(vessels):
        for b in vessels[i + 1:]:
            a_mmsi = str(a.get("mmsi") or a.get("MMSI") or "UNKNOWN_A")
            b_mmsi = str(b.get("mmsi") or b.get("MMSI") or "UNKNOWN_B")

            a_lat, a_lon = a.get("lat"), a.get("lon")
            b_lat, b_lon = b.get("lat"), b.get("lon")

            dist = haversine_km(a_lat, a_lon, b_lat, b_lon)
            if dist is None:
                continue

            a_speed = float(a.get("speed", a.get("sog", 0)) or 0)
            b_speed = float(b.get("speed", b.get("sog", 0)) or 0)

            a_zone = detect_zone(a, ZONES) if "ZONES" in globals() else None
            b_zone = detect_zone(b, ZONES) if "ZONES" in globals() else None

            a_safe = ((a_zone or {}).get("type", "").lower() in ["port", "harbour", "harbor"])
            b_safe = ((b_zone or {}).get("type", "").lower() in ["port", "harbour", "harbor"])

            pair_key = "::".join(sorted([a_mmsi, b_mmsi]))

            if dist <= 2.0 and a_speed < 3 and b_speed < 3 and not a_safe and not b_safe:
                first_seen = RENDEZVOUS_STATE.get(pair_key, now_ts)
                RENDEZVOUS_STATE[pair_key] = first_seen
                minutes = round((now_ts - first_seen) / 60, 1)

                # ===== Advanced Rendezvous Behaviour Scoring =====
                score = 0
                indicators = []

                if dist <= 0.5:
                    score += 30
                    indicators.append("very close vessel proximity")
                elif dist <= 1.0:
                    score += 20
                    indicators.append("close vessel proximity")
                else:
                    score += 10
                    indicators.append("nearby vessel proximity")

                if a_speed < 1 and b_speed < 1:
                    score += 25
                    indicators.append("both vessels nearly stationary")
                elif a_speed < 3 and b_speed < 3:
                    score += 15
                    indicators.append("both vessels moving slowly")

                if not a_safe and not b_safe:
                    score += 20
                    indicators.append("outside safe port/harbour zone")

                if minutes >= 20:
                    score += 25
                    indicators.append("extended rendezvous duration")
                elif minutes >= 10:
                    score += 15
                    indicators.append("sustained rendezvous duration")

                a_type = str(a.get("type") or a.get("ship_type") or "").lower()
                b_type = str(b.get("type") or b.get("ship_type") or "").lower()

                if ("cargo" in a_type and ("fishing" in b_type or "unknown" in b_type)) or ("cargo" in b_type and ("fishing" in a_type or "unknown" in a_type)):
                    score += 20
                    indicators.append("possible mothership/support craft pairing")

                if score >= 80:
                    severity = "CRITICAL"
                elif score >= 55:
                    severity = "HIGH"
                elif score >= 30:
                    severity = "MEDIUM"
                else:
                    severity = "LOW"

                candidates.append({
                    "pair": pair_key,
                    "vessel_a": a_mmsi,
                    "vessel_b": b_mmsi,
                    "distance_km": round(dist, 2),
                    "minutes_close": minutes,
                    "alert_threshold_minutes": 10,
                    "status": "ALERT_READY" if minutes >= 10 else "MONITORING",
                    "severity": severity,
                    "rendezvous_score": score,
                    "indicators": indicators,
                    "lat": a_lat,
                    "lon": a_lon,
                    "zone": ((a_zone or b_zone or {}).get("name") or "Open Water")
                })
            else:
                RENDEZVOUS_STATE.pop(pair_key, None)

    if request.args.get("test") == "1":
        candidates.append({
            "pair": "TEST-MOTHERSHIP::TEST-SMALLCRAFT",
