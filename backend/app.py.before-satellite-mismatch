@app.route("/api/dark-activity", methods=["GET"])
def dark_activity():
    import json
    import time
    from pathlib import Path
    from datetime import datetime, timezone

    ais_path = Path(__file__).resolve().parent / "ais_live.json"
    now_ts = time.time()

    try:
        data = json.loads(ais_path.read_text()) if ais_path.exists() else []
    except Exception as e:
        return jsonify({"status": "error", "message": str(e), "dark_activity": []})

    vessels = list(data.values()) if isinstance(data, dict) else data
    if not isinstance(vessels, list):
        vessels = []

    results = []

    for v in vessels:
        mmsi = str(v.get("mmsi") or v.get("MMSI") or v.get("id") or "UNKNOWN")
        name = v.get("name") or v.get("ship_name") or v.get("ShipName") or mmsi

        ts = (
            v.get("lastSeen")
            or v.get("last_seen")
            or v.get("timestamp")
            or v.get("received_at")
            or v.get("time")
        )

        last_seen_epoch = None

        if isinstance(ts, (int, float)):
            last_seen_epoch = float(ts)
        elif isinstance(ts, str):
            try:
                last_seen_epoch = datetime.fromisoformat(ts.replace("Z", "+00:00")).timestamp()
            except Exception:
                last_seen_epoch = None

        if last_seen_epoch is None:
            continue

        age_minutes = round((now_ts - last_seen_epoch) / 60, 1)

        score = 0
        flags = []

        if age_minutes >= 120:
            score += 60
            flags.append("AIS blackout over 2 hours")
        elif age_minutes >= 60:
            score += 40
            flags.append("AIS blackout over 1 hour")
        elif age_minutes >= 30:
            score += 25
            flags.append("AIS stale over 30 minutes")

        zone = detect_zone(v, ZONES) if "ZONES" in globals() else None
        zone_name = (zone or {}).get("name") or "Open Water"
        zone_type = (zone or {}).get("type") or "unknown"

        if zone and zone_type in ["watch", "corridor"]:
            score += 25
            flags.append("AIS gap near watch/corridor zone")

        if zone_name and any(x in zone_name.lower() for x in ["lau", "samoa", "tonga", "french", "polynesia", "tuamotu", "marquesas"]):
            score += 20
            flags.append("AIS gap near remote Pacific sector")

        try:
            speed = float(v.get("speed", v.get("sog", 0)) or 0)
        except Exception:
            speed = 0

        if speed < 2 and age_minutes >= 30:
            score += 10
            flags.append("last known movement slow/stationary before gap")

        if score >= 80:
            severity = "CRITICAL"
        elif score >= 55:
            severity = "HIGH"
        elif score >= 30:
            severity = "MEDIUM"
        else:
            severity = "LOW"

        if score >= 25:
            results.append({
                "mmsi": mmsi,
                "name": name,
                "lat": v.get("lat"),
                "lon": v.get("lon"),
                "last_seen": ts,
                "age_minutes": age_minutes,
                "zone": zone_name,
                "dark_score": score,
                "severity": severity,
                "flags": flags
            })

    if request.args.get("test") == "1":
        results.append({
            "mmsi": "TEST-DARK-001",
            "name": "TEST DARK VESSEL",
            "lat": -18.9,
            "lon": -177.2,
            "last_seen": "simulated",
            "age_minutes": 145,
            "zone": "Remote Fiji-Lau / Tonga Corridor",
            "dark_score": 95,
            "severity": "CRITICAL",
            "flags": [
                "AIS blackout over 2 hours",
                "AIS gap near remote Pacific sector",
                "last known movement slow/stationary before gap"
            ]
        })

    results = sorted(results, key=lambda x: x.get("dark_score", 0), reverse=True)

    return jsonify({
        "total_dark_activity": len(results),
        "dark_activity": results[:20]
    })

