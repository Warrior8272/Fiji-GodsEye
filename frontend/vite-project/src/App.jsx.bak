import React, { useEffect, useMemo, useState } from "react";
import {
  MapContainer,
  TileLayer,
  CircleMarker,
  Popup,
  Polyline,
} from "react-leaflet";
import "leaflet/dist/leaflet.css";

const API_BASE = "http://127.0.0.1:5000";

const FIJI_CENTER = [-18.1248, 178.4501];
const SOUTH_AMERICA_GATE = [-12.0464, -77.0428];
const PACIFIC_MID_GATE = [-15.0, -140.0];

const BASEMAPS = {
  osm: {
    label: "OpenStreetMap",
    url: "https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png",
    attribution: "&copy; OpenStreetMap contributors",
  },
  esriSatellite: {
    label: "Esri Satellite",
    url: "https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}",
    attribution: "Tiles &copy; Esri",
  },
  esriStreets: {
    label: "Esri Streets",
    url: "https://server.arcgisonline.com/ArcGIS/rest/services/World_Street_Map/MapServer/tile/{z}/{y}/{x}",
    attribution: "Tiles &copy; Esri",
  },
};

function severityColor(severity) {
  if (severity === "high") return "#ef4444";
  if (severity === "medium") return "#f59e0b";
  return "#94a3b8";
}

function safeArray(value) {
  return Array.isArray(value) ? value : [];
}

function formatHours(value) {
  if (value === null || value === undefined || Number.isNaN(value)) return "Unknown";
  return `${Number(value).toFixed(1)} hrs`;
}

function formatNumber(value, digits = 1) {
  if (value === null || value === undefined || Number.isNaN(value)) return "Unknown";
  return Number(value).toFixed(digits);
}

function App() {
  const [ships, setShips] = useState([]);
  const [alerts, setAlerts] = useState([]);
  const [summary, setSummary] = useState(null);
  const [health, setHealth] = useState(null);

  const [loading, setLoading] = useState(true);
  const [lastUpdated, setLastUpdated] = useState(null);
  const [error, setError] = useState("");

  const [showSuspiciousOnly, setShowSuspiciousOnly] = useState(false);
  const [showUnknownOnly, setShowUnknownOnly] = useState(false);
  const [showTimeoutOnly, setShowTimeoutOnly] = useState(false);
  const [showRouteHelpers, setShowRouteHelpers] = useState(true);
  const [alertFilter, setAlertFilter] = useState("all");
  const [searchText, setSearchText] = useState("");
  const [basemap, setBasemap] = useState("esriSatellite");

  const fetchAllData = async () => {
    try {
      setError("");
      setLoading(true);

      const [shipsRes, alertsRes, summaryRes, healthRes] = await Promise.all([
        fetch(`${API_BASE}/api/vessels`),
        fetch(`${API_BASE}/api/alerts`),
        fetch(`${API_BASE}/api/summary`),
        fetch(`${API_BASE}/api/health`),
      ]);

      const shipsData = await shipsRes.json();
      const alertsData = await alertsRes.json();
      const summaryData = await summaryRes.json();
      const healthData = await healthRes.json();

      const vesselList = safeArray(shipsData?.vessels);
      const alertList = safeArray(alertsData?.alerts);

      setShips(vesselList);
      setAlerts(alertList);
      setSummary(summaryData?.summary || null);
      setHealth(healthData || null);
      setLastUpdated(new Date().toLocaleTimeString());

      if (vesselList.length === 0) {
        console.warn("ships fetch returned empty");
      }
    } catch (err) {
      console.error("Fetch failed:", err);
      setError("Could not load backend data. Check Flask is running on port 5000.");
      setShips([]);
      setAlerts([]);
      setSummary(null);
      setHealth(null);
    } finally {
      setLoading(false);
    }
  };

  useEffect(() => {
    fetchAllData();
    const interval = setInterval(fetchAllData, 30000);
    return () => clearInterval(interval);
  }, []);

  const filteredShips = useMemo(() => {
    let data = safeArray(ships);

    if (showSuspiciousOnly) {
      data = data.filter((ship) => ship.suspicious);
    }

    if (showUnknownOnly) {
      data = data.filter((ship) => ship.unknown_vessel);
    }

    if (showTimeoutOnly) {
      data = data.filter((ship) => ship.ais_timeout);
    }

    if (searchText.trim()) {
      const q = searchText.trim().toLowerCase();
      data = data.filter((ship) => {
        const fields = [
          ship.name,
          ship.mmsi,
          ship.imo,
          ship.callsign,
          ship.ship_type,
          ship.flag,
          ship.destination,
          ship.route_risk_label,
        ]
          .filter(Boolean)
          .join(" ")
          .toLowerCase();

        return fields.includes(q);
      });
    }

    return data;
  }, [ships, showSuspiciousOnly, showUnknownOnly, showTimeoutOnly, searchText]);

  const filteredAlerts = useMemo(() => {
    const list = safeArray(alerts);
    if (alertFilter === "all") return list;
    return list.filter((alert) => alert.severity === alertFilter);
  }, [alerts, alertFilter]);

  const mapCenter = useMemo(() => {
    if (filteredShips.length > 0) {
      return [filteredShips[0].lat, filteredShips[0].lon];
    }
    return FIJI_CENTER;
  }, [filteredShips]);

  const currentBasemap = BASEMAPS[basemap] || BASEMAPS.esriSatellite;

  return (
    <div
      style={{
        height: "100vh",
        width: "100%",
        display: "grid",
        gridTemplateColumns: "320px 1fr 360px",
        background: "#0f172a",
        color: "#e5e7eb",
        overflow: "hidden",
        fontFamily: "Arial, sans-serif",
      }}
    >
      {/* LEFT SIDEBAR */}
      <div
        style={{
          borderRight: "1px solid #1e293b",
          padding: "14px",
          overflowY: "auto",
          background: "#111827",
        }}
      >
        <h2 style={{ marginTop: 0, marginBottom: "8px", fontSize: "22px" }}>
          Fiji God&apos;s Eye
        </h2>
        <div style={{ fontSize: "13px", color: "#94a3b8", marginBottom: "16px" }}>
          Phase 9 Dashboard
        </div>

        <button
          onClick={fetchAllData}
          style={{
            width: "100%",
            padding: "10px 12px",
            background: "#2563eb",
            color: "white",
            border: "none",
            borderRadius: "8px",
            cursor: "pointer",
            marginBottom: "12px",
            fontWeight: "bold",
          }}
        >
          Refresh Data
        </button>

        <div
          style={{
            background: "#0f172a",
            border: "1px solid #1e293b",
            borderRadius: "10px",
            padding: "12px",
            marginBottom: "14px",
          }}
        >
          <div style={{ fontWeight: "bold", marginBottom: "8px" }}>System Status</div>
          <div style={{ fontSize: "13px", lineHeight: "1.8" }}>
            <div>Backend: {health?.status || "Unknown"}</div>
            <div>Version: {health?.version || "Unknown"}</div>
            <div>Feed: {health?.feed_source || "Unknown"}</div>
            <div>Last update: {lastUpdated || "Waiting..."}</div>
          </div>
        </div>

        <div
          style={{
            background: "#0f172a",
            border: "1px solid #1e293b",
            borderRadius: "10px",
            padding: "12px",
            marginBottom: "14px",
          }}
        >
          <div style={{ fontWeight: "bold", marginBottom: "10px" }}>Map Layer</div>
          <select
            value={basemap}
            onChange={(e) => setBasemap(e.target.value)}
            style={{
              width: "100%",
              padding: "10px",
              borderRadius: "8px",
              border: "1px solid #334155",
              background: "#020617",
              color: "white",
              outline: "none",
              boxSizing: "border-box",
            }}
          >
            <option value="osm">OpenStreetMap</option>
            <option value="esriSatellite">Esri Satellite</option>
            <option value="esriStreets">Esri Streets</option>
          </select>
        </div>

        <div
          style={{
            background: "#0f172a",
            border: "1px solid #1e293b",
            borderRadius: "10px",
            padding: "12px",
            marginBottom: "14px",
          }}
        >
          <div style={{ fontWeight: "bold", marginBottom: "10px" }}>Search</div>
          <input
            type="text"
            placeholder="Search name, MMSI, IMO..."
            value={searchText}
            onChange={(e) => setSearchText(e.target.value)}
            style={{
              width: "100%",
              padding: "10px",
              borderRadius: "8px",
              border: "1px solid #334155",
              background: "#020617",
              color: "white",
              outline: "none",
              boxSizing: "border-box",
            }}
          />
        </div>

        <div
          style={{
            background: "#0f172a",
            border: "1px solid #1e293b",
            borderRadius: "10px",
            padding: "12px",
            marginBottom: "14px",
          }}
        >
          <div style={{ fontWeight: "bold", marginBottom: "10px" }}>Filters</div>

          <label style={{ display: "block", marginBottom: "8px", fontSize: "14px" }}>
            <input
              type="checkbox"
              checked={showSuspiciousOnly}
              onChange={(e) => setShowSuspiciousOnly(e.target.checked)}
              style={{ marginRight: "8px" }}
            />
            Suspicious only
          </label>

          <label style={{ display: "block", marginBottom: "8px", fontSize: "14px" }}>
            <input
              type="checkbox"
              checked={showUnknownOnly}
              onChange={(e) => setShowUnknownOnly(e.target.checked)}
              style={{ marginRight: "8px" }}
            />
            Unknown vessels only
          </label>

          <label style={{ display: "block", marginBottom: "8px", fontSize: "14px" }}>
            <input
              type="checkbox"
              checked={showTimeoutOnly}
              onChange={(e) => setShowTimeoutOnly(e.target.checked)}
              style={{ marginRight: "8px" }}
            />
            AIS timeout only
          </label>

          <label style={{ display: "block", marginBottom: "8px", fontSize: "14px" }}>
            <input
              type="checkbox"
              checked={showRouteHelpers}
              onChange={(e) => setShowRouteHelpers(e.target.checked)}
              style={{ marginRight: "8px" }}
            />
            Show route helpers
          </label>
        </div>

        <div
          style={{
            background: "#0f172a",
            border: "1px solid #1e293b",
            borderRadius: "10px",
            padding: "12px",
            marginBottom: "14px",
          }}
        >
          <div style={{ fontWeight: "bold", marginBottom: "10px" }}>Summary</div>
          <div style={{ fontSize: "13px", lineHeight: "1.9" }}>
            <div>Total vessels: {summary?.total_vessels ?? 0}</div>
            <div>Suspicious: {summary?.suspicious_vessels ?? 0}</div>
            <div>Unknown: {summary?.unknown_vessels ?? 0}</div>
            <div>AIS timeouts: {summary?.ais_timeouts ?? 0}</div>
            <div>Near Fiji 250 NM: {summary?.near_fiji_250nm ?? 0}</div>
            <div>Corridor matches: {summary?.high_corridor_matches ?? 0}</div>
          </div>
        </div>

        <div
          style={{
            background: "#0f172a",
            border: "1px solid #1e293b",
            borderRadius: "10px",
            padding: "12px",
          }}
        >
          <div style={{ fontWeight: "bold", marginBottom: "10px" }}>Marker Guide</div>
          <div style={{ fontSize: "13px", lineHeight: "1.9" }}>
            <div><span style={{ color: "green" }}>●</span> High confidence</div>
            <div><span style={{ color: "orange" }}>●</span> Medium confidence</div>
            <div><span style={{ color: "yellow" }}>●</span> Low confidence</div>
            <div><span style={{ color: "red" }}>●</span> Suspicious contact</div>
            <div><span style={{ color: "gray" }}>●</span> AIS timeout</div>
          </div>
        </div>
      </div>

      {/* MAP AREA */}
      <div style={{ position: "relative", background: "#020617" }}>
        {loading && (
          <div
            style={{
              position: "absolute",
              top: 15,
              left: 15,
              zIndex: 1000,
              background: "rgba(15,23,42,0.9)",
              padding: "10px 14px",
              borderRadius: "8px",
              border: "1px solid #334155",
            }}
          >
            Loading...
          </div>
        )}

        {error && (
          <div
            style={{
              position: "absolute",
              top: 15,
              left: 15,
              zIndex: 1000,
              background: "rgba(127,29,29,0.95)",
              color: "#fff",
              padding: "10px 14px",
              borderRadius: "8px",
              maxWidth: "420px",
            }}
          >
            {error}
          </div>
        )}

        <div
          style={{
            position: "absolute",
            top: 15,
            right: 15,
            zIndex: 1000,
            background: "rgba(15,23,42,0.92)",
            border: "1px solid #334155",
            borderRadius: "10px",
            padding: "10px 12px",
            fontSize: "13px",
            color: "#e5e7eb",
          }}
        >
          Basemap: {currentBasemap.label}
        </div>

        <MapContainer
          center={mapCenter}
          zoom={5}
          style={{ height: "100%", width: "100%" }}
          worldCopyJump={true}
        >
          <TileLayer
            key={basemap}
            attribution={currentBasemap.attribution}
            url={currentBasemap.url}
          />

          {showRouteHelpers && (
            <>
              <CircleMarker
                center={FIJI_CENTER}
                radius={10}
                pathOptions={{ color: "#3b82f6", fillColor: "#3b82f6", fillOpacity: 0.8 }}
              >
                <Popup>
                  <strong>Fiji Reference Point</strong>
                  <br />
                  Suva reference center
                </Popup>
              </CircleMarker>

              <CircleMarker
                center={SOUTH_AMERICA_GATE}
                radius={8}
                pathOptions={{ color: "#8b5cf6", fillColor: "#8b5cf6", fillOpacity: 0.8 }}
              >
                <Popup>
                  <strong>South America Gate</strong>
                  <br />
                  Lima corridor reference
                </Popup>
              </CircleMarker>

              <CircleMarker
                center={PACIFIC_MID_GATE}
                radius={8}
                pathOptions={{ color: "#06b6d4", fillColor: "#06b6d4", fillOpacity: 0.8 }}
              >
                <Popup>
                  <strong>Pacific Mid Route</strong>
                  <br />
                  Mid-Pacific route helper
                </Popup>
              </CircleMarker>

              <Polyline
                positions={[SOUTH_AMERICA_GATE, PACIFIC_MID_GATE, FIJI_CENTER]}
                pathOptions={{ color: "#38bdf8", weight: 2, dashArray: "6, 8" }}
              />
            </>
          )}

          {filteredShips.map((ship, index) => (
            <CircleMarker
              key={`${ship.mmsi || ship.name || "ship"}-${index}`}
              center={[ship.lat, ship.lon]}
              radius={ship.marker_radius || 8}
              pathOptions={{
                color: ship.marker_color || "yellow",
                fillColor: ship.marker_color || "yellow",
                fillOpacity: 0.75,
                weight: 2,
              }}
            >
              <Popup>
                <div style={{ minWidth: "270px", color: "#111827" }}>
                  <h3 style={{ marginTop: 0, marginBottom: "8px" }}>
                    {ship.name || "Unknown Vessel"}
                  </h3>

                  <div><strong>MMSI:</strong> {ship.mmsi || "Unknown"}</div>
                  <div><strong>IMO:</strong> {ship.imo || "Unknown"}</div>
                  <div><strong>Callsign:</strong> {ship.callsign || "Unknown"}</div>
                  <div><strong>Type:</strong> {ship.ship_type || "Unknown"}</div>
                  <div><strong>Flag:</strong> {ship.flag || "Unknown"}</div>
                  <div><strong>Status:</strong> {ship.status || "Unknown"}</div>
                  <div><strong>Destination:</strong> {ship.destination || "Unknown"}</div>

                  <hr />

                  <div><strong>Speed:</strong> {formatNumber(ship.speed_knots, 1)} knots</div>
                  <div><strong>Course:</strong> {ship.course ?? "Unknown"}° ({ship.course_cardinal || "Unknown"})</div>
                  <div><strong>Heading:</strong> {ship.heading ?? "Unknown"}° ({ship.heading_cardinal || "Unknown"})</div>
                  <div><strong>Distance to Fiji:</strong> {formatNumber(ship.distance_to_fiji_nm, 1)} NM</div>
                  <div><strong>Bearing to Fiji:</strong> {ship.bearing_to_fiji ?? "Unknown"}°</div>
                  <div><strong>Hours since seen:</strong> {formatHours(ship.hours_since_seen)}</div>
                  <div><strong>Confidence:</strong> {ship.confidence_score ?? 0}%</div>

                  <hr />

                  <div><strong>Route label:</strong> {ship.route_risk_label || "Unknown"}</div>
                  <div><strong>Corridor score:</strong> {formatNumber(ship.corridor_score, 2)}</div>
                  <div><strong>Fiji bound:</strong> {ship.fiji_bound ? "Yes" : "No"}</div>
                  <div><strong>Unknown vessel:</strong> {ship.unknown_vessel ? "Yes" : "No"}</div>
                  <div><strong>AIS timeout:</strong> {ship.ais_timeout ? "Yes" : "No"}</div>
                  <div><strong>Loitering:</strong> {ship.loitering ? "Yes" : "No"}</div>
                  <div><strong>Speed anomaly:</strong> {ship.speed_anomaly ? "Yes" : "No"}</div>
                  <div><strong>Suspicious:</strong> {ship.suspicious ? "Yes" : "No"}</div>

                  {safeArray(ship.alerts).length > 0 && (
                    <>
                      <hr />
                      <strong>Alerts</strong>
                      <ul style={{ paddingLeft: "18px", marginBottom: 0 }}>
                        {ship.alerts.map((alert, i) => (
                          <li key={i}>
                            {alert.title}: {alert.message}
                          </li>
                        ))}
                      </ul>
                    </>
                  )}
                </div>
              </Popup>
            </CircleMarker>
          ))}
        </MapContainer>
      </div>

      {/* RIGHT SIDEBAR */}
      <div
        style={{
          borderLeft: "1px solid #1e293b",
          padding: "14px",
          overflowY: "auto",
          background: "#111827",
        }}
      >
        <div
          style={{
            display: "flex",
            justifyContent: "space-between",
            alignItems: "center",
            marginBottom: "12px",
          }}
        >
          <h3 style={{ margin: 0 }}>Alerts</h3>
          <select
            value={alertFilter}
            onChange={(e) => setAlertFilter(e.target.value)}
            style={{
              background: "#020617",
              color: "white",
              border: "1px solid #334155",
              borderRadius: "8px",
              padding: "8px",
            }}
          >
            <option value="all">All</option>
            <option value="high">High</option>
            <option value="medium">Medium</option>
            <option value="low">Low</option>
          </select>
        </div>

        <div style={{ fontSize: "13px", color: "#94a3b8", marginBottom: "12px" }}>
          Showing {filteredAlerts.length} alerts and {filteredShips.length} vessels
        </div>

        {filteredAlerts.length === 0 ? (
          <div
            style={{
              background: "#0f172a",
              border: "1px solid #1e293b",
              borderRadius: "10px",
              padding: "14px",
              color: "#94a3b8",
            }}
          >
            No alerts for current filter.
          </div>
        ) : (
          filteredAlerts.map((alert, index) => (
            <div
              key={`${alert.type || "alert"}-${index}`}
              style={{
                background: "#0f172a",
                border: `1px solid ${severityColor(alert.severity)}`,
                borderRadius: "10px",
                padding: "12px",
                marginBottom: "12px",
              }}
            >
              <div
                style={{
                  display: "inline-block",
                  background: severityColor(alert.severity),
                  color: "white",
                  borderRadius: "999px",
                  padding: "3px 8px",
                  fontSize: "11px",
                  fontWeight: "bold",
                  marginBottom: "8px",
                  textTransform: "uppercase",
                }}
              >
                {alert.severity || "unknown"}
              </div>

              <div style={{ fontWeight: "bold", marginBottom: "6px" }}>
                {alert.title || "Untitled alert"}
              </div>

              <div style={{ fontSize: "14px", marginBottom: "8px", lineHeight: "1.5" }}>
                {alert.message || "No message"}
              </div>

              <div style={{ fontSize: "13px", color: "#cbd5e1", lineHeight: "1.7" }}>
                <div><strong>Vessel:</strong> {alert.name || "Unknown"}</div>
                <div><strong>MMSI:</strong> {alert.mmsi || "Unknown"}</div>
                <div><strong>Type:</strong> {alert.ship_type || "Unknown"}</div>
                <div><strong>Speed:</strong> {formatNumber(alert.speed_knots, 1)} knots</div>
                <div><strong>Distance to Fiji:</strong> {formatNumber(alert.distance_to_fiji_nm, 1)} NM</div>
                <div><strong>Confidence:</strong> {alert.confidence_score ?? 0}%</div>
                <div><strong>Last seen:</strong> {alert.last_seen_iso || "Unknown"}</div>
              </div>
            </div>
          ))
        )}
      </div>
    </div>
  );
}

export default App;
