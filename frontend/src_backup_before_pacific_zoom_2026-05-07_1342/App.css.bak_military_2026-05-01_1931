html, body, #root {
  width: 100%;
  height: 100%;
  margin: 0;
  padding: 0;
}

body {
  overflow: hidden;
}

* {
  box-sizing: border-box;
}

.app,
.dashboard,
.godseye-app,
.main-layout,
.map-layout,
.content,
.map-shell,
.map-container {
  width: 100vw !important;
  max-width: none !important;
  min-width: 0 !important;
}

.app,
.dashboard,
.godseye-app {
  height: 100vh !important;
  display: flex;
  flex-direction: column;
}

.main-layout,
.map-layout,
.content,
.map-shell {
  flex: 1 1 auto !important;
  height: 100% !important;
  display: flex;
}

.leaflet-container {
  width: 100% !important;
  height: 100% !important;
}

.left-panel,
.right-panel,
.alert-panel,
.watchlist-panel {
  max-width: 360px;
  z-index: 1000;
}
